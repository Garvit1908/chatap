# Server Environment Variables Configuration
PORT=5000
NODE_ENV=development

# MongoDB connection URI (Atlas SRV or local connection string)
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/talkflow

# JWT secret key for signature validation (Make sure to generate a secure random hex key in production)
JWT_SECRET=supersecret123

# Email verification via Brevo API
BREVO_API_KEY=your_brevo_api_key
BREVO_SENDER_EMAIL=your_sender_email@gmail.com

# Google OAuth integration (Frontend client ID should match)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# OpenRouter key for AI assistant (TalkBot)
OPENROUTER_API_KEY=your_openrouter_api_key

# CORS allowed origins list (comma-separated, without trailing slashes)
CORS_ORIGINS=http://localhost:5173,https://talkflow-frontend.onrender.com
